# =============================================
# 環境変数テンプレート
# =============================================
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
#
# 【重要】 .env ファイルは絶対にコミットしないでください。
# .gitignore で除外済みですが、念のため注意してください。

# Azure OpenAI (例)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_KEY=your-api-key-here
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.4-mini

# Azure 全般 (例)
# AZURE_SUBSCRIPTION_ID=
# AZURE_RESOURCE_GROUP=

# 認証 (本番は必須、ローカルは uvicorn 起動時のみ必要)
# JWT_SECRET_KEY=  # python3 -c 'import secrets; print(secrets.token_urlsafe(48))' で生成
# JWT_EXPIRE_HOURS=24
# JWT_ISSUER=orderai-api
# JWT_AUDIENCE=orderai-dashboard

# Microsoft Entra ID SSO
# ENTRA_TENANT_ID=  # M365 テナント ID（シングルテナント強制）
# ENTRA_CLIENT_ID=  # アプリ登録のクライアント ID
# ENTRA_CLIENT_SECRET=  # アプリ登録のクライアントシークレット
# ENTRA_REDIRECT_URI=http://localhost:8080/api/auth/callback/microsoft
# AZURE_AD_ALLOWED_TENANTS=  # ENTRA_TENANT_ID の代わりにカンマ区切りで複数指定可（未設定時は ENTRA_TENANT_ID を使用）
# AZURE_AD_ALLOWED_DOMAINS=  # 任意。email/UPN ドメイン allowlist

# SSO でログインしたユーザーのデフォルトテナント
# SSO_DEFAULT_TENANT=T-001

# セルフ登録（招待制）
# REGISTRATION_ENABLED=false
# REGISTRATION_INVITE_TOKEN=

# Phone webhook 共有鍵 (ACS Call Automation を使う場合は必須)
# EVENTGRID_WEBHOOK_KEY=  # EventGrid サブスクリプション URL の ?code= と一致させる

# メール送信ルーティング（任意）
# EMAIL_INTERNAL_DOMAINS=aibaske1103gmail.onmicrosoft.com
# EMAIL_EXTERNAL_ROUTE_MODE=delegated_first   # delegated_first | delegated_only | smtp_only | app_only
# EMAIL_EXTERNAL_FALLBACK_PROVIDER=smtp       # 現在は smtp のみ実装
#
# delegated(Graphユーザー委任)送信用:
# GRAPH_DELEGATED_ACCESS_TOKEN=         # 短期デモ向け（期限あり）
# GRAPH_DELEGATED_REFRESH_TOKEN=
# GRAPH_DELEGATED_SCOPE=https://graph.microsoft.com/Mail.Send offline_access
# GRAPH_DELEGATED_SEND_AS_USER_ID=      # 未指定時は GRAPH_MAILBOX_USER_ID
#
# SMTPフォールバック送信用:
# SMTP_FALLBACK_HOST=
# SMTP_FALLBACK_PORT=587
# SMTP_FALLBACK_USERNAME=
# SMTP_FALLBACK_PASSWORD=
# SMTP_FALLBACK_FROM_ADDRESS=
# SMTP_FALLBACK_STARTTLS=true
